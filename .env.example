# === PokeMatrix Server Configuration ===
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5173

# JWT Secret (auto-generated if empty, set in production!)
# JWT_SECRET=your-secure-random-string-here

# Admin
# ADMIN_PASS=your-admin-password

# Data directory (default: server/data/)
# DATA_DIR=

# Logging
# LOG_LEVEL=debug|info|warn|error
# PINO_PRETTY=1

# Telegram Bot (for chat features)
# BOT_TOKEN=

# Rate limiting
# RATE_LIMIT_MAX=500
# SAVE_RATE_LIMIT_MAX=30

# PokeAPI
# POKEAPI_BASE_URL=https://pokeapi.co
